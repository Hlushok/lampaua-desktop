{
  "name": "lampaua-desktop",
  "productName": "LampaUa",
  "version": "1.5.0",
  "description": "Десктопний клієнт LampaUa",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hlushok/lampaua-desktop"
  },
  "main": "src/main.js",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "npm": "please-use-yarn",
    "yarn": ">= 4.0.0"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build-linux": "electron-builder --linux --publish=never",
    "build-mac": "electron-builder --mac --publish=never",
    "build-win": "electron-builder --win --publish=never",
    "lint": "yarn lint:eslint && yarn lint:prettier",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier . --check",
    "lintfix": "eslint . --fix && prettier --write --list-different .",
    "release:changelog": "commit-and-tag-version",
    "release": "yarn release:changelog && git push --follow-tags origin $CI_COMMIT_REF_NAME"
  },
  "commit-and-tag-version": {
    "scripts": {
      "postchangelog": "yarn lintfix"
    }
  },
  "dependencies": {
    "electron-store": "11.0.2",
    "electron-updater": "6.8.3",
    "which": "6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "commit-and-tag-version": "12.7.1",
    "electron": "41.5.0",
    "electron-builder": "26.8.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.6.0",
    "prettier": "3.8.3"
  },
  "author": {
    "name": "yumata, Kolovatoff, Hlushok",
    "email": "stpuh2@gmail.com"
  },
  "license": "GPL-2.0",
  "build": {
    "appId": "com.lampaua.desktop",
    "productName": "LampaUa",
    "artifactName": "lampaua-${arch}-${version}.${ext}",
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        "AppImage"
      ],
      "icon": "assets/linux.icns",
      "category": "Multimedia"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/mac.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32",
            "arm64"
          ]
        }
      ],
      "icon": "assets/win.ico",
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": false,
      "installerIcon": "assets/win.ico",
      "uninstallerIcon": "assets/win.ico",
      "license": "LICENSE"
    },
    "publish": {
      "provider": "github",
      "owner": "Hlushok",
      "repo": "lampaua-desktop"
    }
  },
  "files": [
    "assets/**/*",
    "src/**/*",
    "node_modules/*",
    "!dist/*"
  ],
  "packageManager": "yarn@4.14.1"
}
